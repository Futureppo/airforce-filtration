# 格式: http://ip:port
# PROXY_URL=http://user:pass@ip:port

# 上游 API 地址
UPSTREAM_URL=https://api.airforce

# 代理监听端口（默认: 6777）
LISTEN_PORT=6777

# 429 错误时最大重试次数（默认: 3）
MAX_RETRIES=3

# 自定义广告过滤关键词，用 | 分隔（留空则使用默认关键词）
# 默认关键词: Need proxies cheaper than the market? | op.wtf | Upgrade your plan to remove this message | discord.gg/airforce
AD_KEYWORDS=

# 流式响应尾部缓冲区大小（字符数，默认: 400）
# 用于检测和过滤结尾广告，过大会增加延迟，过小可能漏过广告
AD_BUFFER_SIZE=400
